# Story generation
MISTRAL_API_KEY=your_mistral_api_key_here
MODEL_NAME=mistral-large-latest
CHANNEL_NAME=Tiny Good Habits
VOICE=en-US-AnaNeural
THEME=kindness
AGE_RANGE=4-8
VIDEO_SECONDS=35

# Webapp
ADMIN_PASSWORD=your_admin_password_here
SECRET_KEY=your_random_secret_key_here

# Supabase (production) — leave blank to use local storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Upload script
RENDER_URL=https://your-app.onrender.com

# ElevenLabs — comma-separated list, one is picked randomly per story
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_IDS=voiceId1,voiceId2,voiceId3

# Hugging Face (for FLUX image generation)
HF_TOKEN=your_huggingface_token_here

# Gumroad premium membership
# Get access token: gumroad.com → Settings → Advanced → Access Token
# Product URL: your Gumroad subscription product page link
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here
GUMROAD_PRODUCT_ID=your_gumroad_product_id_here
GUMROAD_PRODUCT_URL=https://yourname.gumroad.com/l/your-product-slug
